import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { TemplateCard, SessionCard, WeekdayProgress } from "../types.slint";
import { UiVars } from "../theme.slint";
import { Panel, SectionLabel, SmallNote, ActionButton } from "../components.slint";
import { DynamicIcon } from "../generated_icons.slint";

export component HomeScreen inherits Rectangle {
    in property <int> featured-template-id: -1;
    in property <string> featured-template-name: "BUILD YOUR FIRST TEMPLATE";
    in property <string> featured-template-icon: "chest";
    in property <string> featured-template-meta: "0 EXERCISES - CUSTOM SETUP";
    in property <string> featured-template-detail: "Create a clean session flow, then launch from Home.";
    in property <string> featured-template-cta: "OPEN PLANNER";

    in property <[TemplateCard]> templates: [];
    in property <[SessionCard]> recent-sessions: [];
    in property <[WeekdayProgress]> week-progress: [];

    callback open-planner();
    callback start-workout(int);
    callback edit-template(int);
    callback delete-template(int);

    background: UiVars.screen-bg;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            alignment: start;
            padding-left: UiVars.page-padding;
            padding-right: UiVars.page-padding;
            spacing: 0;

            SectionLabel { text: "TODAY'S PROTOCOL"; }
            Rectangle { height: UiVars.section-title-gap; }

            Rectangle {
                horizontal-stretch: 1;
                height: 146px;

                Panel {
                    width: parent.width;
                    height: parent.height;
                    fill: UiVars.panel-bg-strong;

                    Text {
                        x: 18px;
                        y: 16px;
                        width: parent.width - 72px;
                        text: root.featured-template-name;
                        color: UiVars.ink;
                        font-size: 22px;
                        font-weight: 800;
                        wrap: word-wrap;
                    }

                    if root.featured-template-meta != "" : Text {
                        x: 18px;
                        y: 52px;
                        width: parent.width - 36px;
                        text: root.featured-template-meta;
                        color: UiVars.ink-soft;
                        font-size: 11px;
                        font-weight: 700;
                        letter-spacing: 1px;
                    }

                    if root.featured-template-detail != "" : SmallNote {
                        x: 18px;
                        y: root.featured-template-meta == "" ? 52px : 74px;
                        width: parent.width - 36px;
                        text: root.featured-template-detail;
                        font-size: 13px;
                    }

                    if root.featured-template-id < 0 : Text {
                        x: parent.width - 44px;
                        y: 14px;
                        text: "+";
                        color: UiVars.accent-deep;
                        font-size: 20px;
                        font-weight: 900;
                    }

                    if root.featured-template-id >= 0 : DynamicIcon {
                        x: parent.width - 46px;
                        y: 10px;
                        width: 32px;
                        height: 32px;
                        icon-name: root.featured-template-icon;
                    }

                    ActionButton {
                        x: 18px;
                        y: parent.height - 50px;
                        width: parent.width - 36px;
                        height: 34px;
                        label: root.featured-template-cta;
                        clicked => {
                            if root.featured-template-id < 0 {
                                root.open-planner();
                            } else {
                                root.start-workout(root.featured-template-id);
                            }
                        }
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "WEEKLY PROGRESS"; }
            Rectangle { height: UiVars.section-title-gap; }

            Panel {
                horizontal-stretch: 1;
                border-width: UiVars.border-width;
                drop-shadow-color: UiVars.ink;
                drop-shadow-offset-x: 4px;
                drop-shadow-offset-y: 4px;
                drop-shadow-blur: 0px;

                property <length> wp-pad: 16px;
                property <length> wp-gap: 8px;
                property <length> wp-cell: (self.width - 2 * wp-pad - 6 * wp-gap) / 7;
                property <length> wp-label-h: 20px;
                height: wp-pad + wp-label-h + wp-gap + wp-cell + wp-pad;

                for day[idx] in root.week-progress : Rectangle {
                    x: parent.wp-pad + idx * (parent.wp-cell + parent.wp-gap);
                    y: parent.wp-pad;
                    width: parent.wp-cell;
                    height: 20px + 8px + parent.wp-cell;

                    Text {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: 20px;
                        text: day.label;
                        color: day.current ? UiVars.ink : UiVars.ink-muted;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        x: 0;
                        y: 28px;
                        width: parent.width;
                        height: parent.width;
                        background: day.active ? UiVars.accent : UiVars.screen-bg;
                        border-color: day.current ? UiVars.ink : UiVars.border-soft;
                        border-width: UiVars.border-width;

                        if day.active : DynamicIcon {
                            width: 24px;
                            height: 24px;
                            x: (parent.width - 24px) / 2;
                            y: (parent.height - 24px) / 2;
                            icon-name: day.icon;
                        }
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "HISTORY"; }
            Rectangle { height: UiVars.section-title-gap; }

            for session in root.recent-sessions : Rectangle {
                horizontal-stretch: 1;
                height: 54px;

                Panel {
                    width: parent.width;
                    height: parent.height;

                    if session.icon != "" : Rectangle {
                        x: 10px;
                        y: 10px;
                        width: 26px;
                        height: 26px;
                        background: UiVars.panel-bg-soft;
                        border-color: UiVars.quiet-stroke;
                        border-width: 1px;

                        DynamicIcon {
                            width: 26px;
                            height: 26px;
                            x: (parent.width - 26px) / 2;
                            y: (parent.height - 26px) / 2;
                            icon-name: session.icon;
                        }
                    }

                    Text {
                        x: session.icon != "" ? 46px : 14px;
                        y: 10px;
                        width: parent.width - (session.icon != "" ? 84px : 52px);
                        text: session.title;
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 800;
                        overflow: elide;
                    }

                    Text {
                        x: session.icon != "" ? 46px : 14px;
                        y: 28px;
                        width: parent.width - (session.icon != "" ? 84px : 52px);
                        text: session.subtitle;
                        color: UiVars.ink-muted;
                        font-size: 9px;
                        font-weight: 700;
                        letter-spacing: 0.8px;
                        overflow: elide;
                    }

                }

                Rectangle { height: 8px; }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "PLANS"; }
            Rectangle { height: UiVars.section-title-gap; }

            for template in root.templates : Rectangle {
                horizontal-stretch: 1;
                height: template.id < 0 ? 88px : 128px;

                Panel {
                    width: parent.width;
                    height: parent.height;

                    if template.id >= 0 : Rectangle {
                        x: 14px;
                        y: 14px;
                        width: 42px;
                        height: 42px;
                        background: UiVars.surface;
                        border-color: UiVars.ink;
                        border-width: UiVars.border-width;

                        DynamicIcon {
                            width: 34px;
                            height: 34px;
                            x: (parent.width - 34px) / 2;
                            y: (parent.height - 34px) / 2;
                            icon-name: template.icon;
                        }
                    }

                    Text {
                        x: template.id < 0 ? 14px : 68px;
                        y: template.id < 0 ? (parent.height / 2 - 12px) : 10px;
                        width: parent.width - (template.id < 0 ? 86px : 158px);
                        text: template.name;
                        color: UiVars.ink;
                        font-size: 17px;
                        font-weight: 800;
                        wrap: word-wrap;
                    }

                    if template.id >= 0 : Text {
                        x: 68px;
                        y: 38px;
                        width: parent.width - 158px;
                        text: template.days;
                        color: UiVars.ink-soft;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 1px;
                        overflow: elide;
                    }

                    if template.id >= 0 : SmallNote {
                        x: 68px;
                        y: 54px;
                        width: parent.width - 158px;
                        text: template.info;
                    }

                    ActionButton {
                        x: parent.width - 90px;
                        y: 18px;
                        width: 72px;
                        height: 50px;
                        label: template.id < 0 ? "PLAN" : "START";
                        fill: UiVars.accent;
                        outlined: false;
                        clicked => {
                            if template.id < 0 {
                                root.open-planner();
                            } else {
                                root.start-workout(template.id);
                            }
                        }
                    }

                    if template.id >= 0 : HorizontalBox {
                        x: 14px;
                        y: 82px;
                        width: parent.width - 28px;
                        height: 32px;
                        padding: 0;
                        spacing: 8px;

                        ActionButton {
                            horizontal-stretch: 1;
                            label: "EDIT";
                            fill: UiVars.surface;
                            outlined: true;
                            clicked => { root.edit-template(template.id); }
                        }

                        ActionButton {
                            horizontal-stretch: 1;
                            label: "DELETE";
                            fill: UiVars.surface;
                            outlined: true;
                            clicked => { root.delete-template(template.id); }
                        }
                    }
                }

                Rectangle { height: 10px; }
            }

            Rectangle { height: 10px; }
        }
    }
}
