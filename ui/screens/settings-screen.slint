import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { UiVars } from "../theme.slint";
import { SectionLabel, SmallNote, ActionButton, BrutalistDropdown } from "../components.slint";

component SettingsCard inherits Rectangle {
    in property <color> fill: UiVars.surface;

    background: root.fill;
    border-color: UiVars.ink;
    border-width: UiVars.border-width;
    drop-shadow-color: UiVars.ink;
    drop-shadow-offset-x: 3px;
    drop-shadow-offset-y: 3px;
    drop-shadow-blur: 0px;
}

component SettingsSectionHeading inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    height: 40px;
    background: transparent;

    Text {
        x: 0;
        y: 0;
        width: parent.width * 0.62;
        height: parent.height;
        text: root.title;
        color: UiVars.ink;
        font-size: 13px;
        font-weight: 900;
        letter-spacing: 1.2px;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    Text {
        x: parent.width - 118px;
        y: 2px;
        width: 118px;
        height: parent.height - 4px;
        text: root.subtitle;
        color: UiVars.ink-soft;
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 1.6px;
        horizontal-alignment: right;
        vertical-alignment: center;
        wrap: word-wrap;
    }
}

component SettingsThemeButton inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> active: false;
    callback pressed;

    background: root.active ? UiVars.accent : UiVars.surface;
    border-color: UiVars.ink;
    border-width: UiVars.border-width;

    Text {
        x: 12px;
        width: parent.width - 44px;
        height: parent.height;
        text: root.label;
        color: UiVars.ink;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 1px;
        vertical-alignment: center;
    }

    Text {
        x: parent.width - 28px;
        width: 20px;
        height: parent.height;
        text: root.icon;
        color: UiVars.ink;
        font-size: 16px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        clicked => { root.pressed(); }
    }
}

component SettingsColorChip inherits Rectangle {
    in property <color> swatch;
    in property <bool> active: false;
    callback pressed;

    width: 34px;
    height: 34px;
    background: root.swatch;
    border-color: UiVars.ink;
    border-width: root.active ? 3px : UiVars.border-width;
    drop-shadow-color: root.active ? UiVars.ink : transparent;
    drop-shadow-offset-x: root.active ? 2px : 0px;
    drop-shadow-offset-y: root.active ? 2px : 0px;
    drop-shadow-blur: 0px;

    TouchArea {
        clicked => { root.pressed(); }
    }
}

component SettingsTextField inherits Rectangle {
    in property <string> label;
    in-out property <string> value;
    in property <string> placeholder: "";
    callback value-edited;

    height: 74px;
    background: transparent;

    Text {
        x: 0;
        y: 0;
        width: parent.width;
        height: 18px;
        text: root.label;
        color: UiVars.ink-soft;
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 1.4px;
        vertical-alignment: center;
    }

    Rectangle {
        y: 24px;
        width: parent.width;
        height: 42px;
        background: UiVars.surface;
        border-color: input.has-focus ? UiVars.accent : UiVars.ink;
        border-width: UiVars.border-width;

        input := TextInput {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text <=> root.value;
            color: UiVars.ink;
            font-size: 13px;
            font-weight: 800;
            vertical-alignment: center;
            single-line: true;
            edited => { root.value-edited(); }
        }

        if root.value == "" : Text {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.placeholder;
            color: UiVars.ink-muted;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

component SettingsValueField inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <string> unit: "";
    in-out property <string> value;
    in property <string> placeholder: "";

    height: 72px;
    background: UiVars.surface;
    border-color: UiVars.ink;
    border-width: UiVars.border-width;

    Text {
        x: 12px;
        y: 10px;
        width: parent.width - 128px;
        height: 18px;
        text: root.label;
        color: UiVars.ink;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.9px;
        vertical-alignment: center;
    }

    Text {
        x: 12px;
        y: 28px;
        width: parent.width - 128px;
        height: 26px;
        text: root.hint;
        color: UiVars.ink-soft;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.8px;
        wrap: word-wrap;
    }

    Rectangle {
        x: parent.width - 96px;
        y: 14px;
        width: 82px;
        height: 42px;
        background: UiVars.surface;
        border-color: input.has-focus ? UiVars.accent : UiVars.ink;
        border-width: UiVars.border-width;

        input := TextInput {
            x: 8px;
            width: parent.width - (root.unit == "" ? 16px : 34px);
            height: parent.height;
            text <=> root.value;
            color: UiVars.ink;
            font-size: 18px;
            font-weight: 900;
            horizontal-alignment: right;
            vertical-alignment: center;
            single-line: true;
        }

        if root.value == "" : Text {
            x: 8px;
            width: parent.width - (root.unit == "" ? 16px : 34px);
            height: parent.height;
            text: root.placeholder;
            color: UiVars.ink-muted;
            font-size: 18px;
            font-weight: 800;
            horizontal-alignment: right;
            vertical-alignment: center;
        }

        if root.unit != "" : Text {
            x: parent.width - 22px;
            width: 16px;
            height: parent.height;
            text: root.unit;
            color: UiVars.ink-soft;
            font-size: 9px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component SettingsValueDropdownField inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <[string]> model;
    in-out property <string> value;

    height: 72px;
    background: UiVars.surface;
    border-color: UiVars.ink;
    border-width: UiVars.border-width;

    Text {
        x: 12px;
        y: 10px;
        width: parent.width - 128px;
        height: 18px;
        text: root.label;
        color: UiVars.ink;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.9px;
        vertical-alignment: center;
    }

    Text {
        x: 12px;
        y: 28px;
        width: parent.width - 128px;
        height: 26px;
        text: root.hint;
        color: UiVars.ink-soft;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.8px;
        wrap: word-wrap;
    }

    BrutalistDropdown {
        x: parent.width - 96px;
        y: 14px;
        width: 82px;
        height: 42px;
        model: root.model;
        current-value <=> root.value;
    }
}

component SettingsActionTile inherits Rectangle {
    in property <string> label;
    in property <string> detail: "";
    in property <color> fill: UiVars.surface;
    in property <color> text-color: UiVars.ink;
    callback pressed;

    background: root.fill;
    border-color: UiVars.ink;
    border-width: UiVars.border-width;
    drop-shadow-color: UiVars.ink;
    drop-shadow-offset-x: 3px;
    drop-shadow-offset-y: 3px;
    drop-shadow-blur: 0px;

    Text {
        x: 10px;
        y: root.detail == "" ? 0px : 16px;
        width: parent.width - 20px;
        height: root.detail == "" ? parent.height : 26px;
        text: root.label;
        color: root.text-color;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.9px;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    if root.detail != "" : Text {
        x: 10px;
        y: parent.height - 28px;
        width: parent.width - 20px;
        height: 18px;
        text: root.detail;
        color: root.text-color;
        opacity: 0.72;
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 0.7px;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    TouchArea {
        clicked => { root.pressed(); }
    }
}

component SettingsInfoCard inherits Rectangle {
    in property <string> label;
    in property <string> value;

    height: 78px;
    background: UiVars.surface;
    border-color: UiVars.ink;
    border-width: UiVars.border-width;

    Text {
        x: 12px;
        y: 10px;
        width: parent.width - 24px;
        height: 18px;
        text: root.label;
        color: UiVars.ink-soft;
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 1.2px;
        vertical-alignment: center;
    }

    Text {
        x: 12px;
        y: 30px;
        width: parent.width - 24px;
        height: parent.height - 40px;
        text: root.value;
        color: UiVars.ink;
        font-size: 10px;
        font-weight: 700;
        wrap: word-wrap;
        vertical-alignment: top;
    }
}

export component SettingsScreen inherits Rectangle {
    in-out property <string> accent-color;
    in-out property <string> background-color;
    in-out property <string> text-color;
    in-out property <string> default-rest;
    in-out property <string> weight-unit;
    in-out property <string> set-count;
    in-out property <string> rep-target;
    in property <string> last-export;
    in property <string> app-version;
    in property <string> schema-version;

    callback save-settings;
    callback reset-colors;
    callback reset-defaults;
    callback apply-theme-live;
    callback export-all-data;
    callback import-latest-export;
    callback reset-all-data;

    property <bool> light-mode-active: (root.background-color == "#EFEDE8" || root.background-color == "#efede8") && root.text-color == "#111111";

    background: UiVars.screen-bg;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            alignment: start;
            padding-top: UiVars.page-padding;
            padding-left: 0px;
            padding-right: 0px;
            padding-bottom: 34px;
            spacing: 16px;

            VerticalBox {
                horizontal-stretch: 1;
                spacing: 8px;

                SettingsSectionHeading {
                    horizontal-stretch: 1;
                    title: "WORKOUT DEFAULTS";
                    subtitle: "PERFORMANCE PRESETS";
                }

                SettingsCard {
                    horizontal-stretch: 1;
                    height: 342px;

                    VerticalBox {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        padding-left: 0px;
                        padding-right: 0px;
                        spacing: 10px;

                        SettingsValueField {
                            horizontal-stretch: 1;
                            label: "REST TIME BETWEEN SETS";
                            hint: "Auto-start timer after a completed set.";
                            unit: "SEC";
                            value <=> root.default-rest;
                            placeholder: "90";
                        }

                        SettingsValueField {
                            horizontal-stretch: 1;
                            label: "DEFAULT SET COUNT";
                            hint: "Standard volume for newly created exercises.";
                            unit: "SETS";
                            value <=> root.set-count;
                            placeholder: "3";
                        }

                        SettingsValueField {
                            horizontal-stretch: 1;
                            label: "REP TARGET RANGE";
                            hint: "Hypertrophy versus strength default target.";
                            unit: "REPS";
                            value <=> root.rep-target;
                            placeholder: "8";
                        }

                        SettingsValueDropdownField {
                            horizontal-stretch: 1;
                            label: "WEIGHT UNIT";
                            hint: "Primary unit shown in workouts and stats.";
                            model: ["Kg", "Lbs"];
                            value <=> root.weight-unit;
                        }
                    }
                }
            }

            VerticalBox {
                horizontal-stretch: 1;
                spacing: 8px;

                SettingsSectionHeading {
                    horizontal-stretch: 1;
                    title: "APPEARANCE";
                    subtitle: "VISUAL INTERFACE";
                }

                SettingsCard {
                    horizontal-stretch: 1;
                    height: 78px;

                    SmallNote {
                        x: 0px;
                        y: 10px;
                        width: parent.width;
                        text: "SYSTEM THEME";
                    }

                    SettingsThemeButton {
                        x: 0px;
                        y: 30px;
                        width: parent.width;
                        height: 34px;
                        label: "LIGHT MODE";
                        icon: "☀";
                        active: root.light-mode-active;
                        pressed => {
                            root.background-color = "#EFEDE8";
                            root.text-color = "#111111";
                            root.apply-theme-live();
                        }
                    }
                }
            }

            SettingsCard {
                horizontal-stretch: 1;
                height: 92px;

                SmallNote {
                    x: 0px;
                    y: 10px;
                    width: parent.width;
                    text: "ACCENT COLOR";
                }

                HorizontalBox {
                    x: 0px;
                    y: 34px;
                    width: parent.width;
                    height: 38px;
                    padding: 0;
                    spacing: 10px;

                    SettingsColorChip {
                        swatch: #F2CF00;
                        active: root.accent-color == "#F2CF00" || root.accent-color == "#f2cf00";
                        pressed => {
                            root.accent-color = "#F2CF00";
                            root.apply-theme-live();
                        }
                    }
                    SettingsColorChip {
                        swatch: #FF5A36;
                        active: root.accent-color == "#FF5A36" || root.accent-color == "#ff5a36";
                        pressed => {
                            root.accent-color = "#FF5A36";
                            root.apply-theme-live();
                        }
                    }
                    SettingsColorChip {
                        swatch: #36E85A;
                        active: root.accent-color == "#36E85A" || root.accent-color == "#36e85a";
                        pressed => {
                            root.accent-color = "#36E85A";
                            root.apply-theme-live();
                        }
                    }
                    SettingsColorChip {
                        swatch: #4468F1;
                        active: root.accent-color == "#4468F1" || root.accent-color == "#4468f1";
                        pressed => {
                            root.accent-color = "#4468F1";
                            root.apply-theme-live();
                        }
                    }
                    SettingsColorChip {
                        swatch: #D93FE0;
                        active: root.accent-color == "#D93FE0" || root.accent-color == "#d93fe0";
                        pressed => {
                            root.accent-color = "#D93FE0";
                            root.apply-theme-live();
                        }
                    }
                }
            }

            SettingsCard {
                horizontal-stretch: 1;
                height: 286px;

                SmallNote {
                    x: 0px;
                    y: 10px;
                    width: parent.width;
                    text: "CUSTOM PALETTE";
                }

                SettingsTextField {
                    x: 0px;
                    y: 28px;
                    width: parent.width;
                    label: "ACCENT HEX";
                    value <=> root.accent-color;
                    placeholder: "#F2CF00";
                    value-edited => { root.apply-theme-live(); }
                }

                SettingsTextField {
                    x: 0px;
                    y: 102px;
                    width: parent.width;
                    label: "BACKGROUND HEX";
                    value <=> root.background-color;
                    placeholder: "#EFEDE8";
                    value-edited => { root.apply-theme-live(); }
                }

                SettingsTextField {
                    x: 0px;
                    y: 176px;
                    width: parent.width;
                    label: "TEXT HEX";
                    value <=> root.text-color;
                    placeholder: "#111111";
                    value-edited => { root.apply-theme-live(); }
                }

                ActionButton {
                    x: 0px;
                    y: 244px;
                    width: parent.width;
                    height: 30px;
                    label: "RESET APPEARANCE";
                    outlined: true;
                    clicked => { root.reset-colors(); }
                }
            }

            VerticalBox {
                horizontal-stretch: 1;
                spacing: 8px;

                SettingsSectionHeading {
                    horizontal-stretch: 1;
                    title: "DATA MANAGEMENT";
                    subtitle: "PRIVACY & STORAGE";
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: 102px;
                    background: transparent;

                    HorizontalBox {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: 102px;
                        padding: 0;
                        spacing: 10px;

                        SettingsActionTile {
                            horizontal-stretch: 1;
                            label: "EXPORT DATA";
                            detail: "Create a portable local export.";
                            pressed => { root.export-all-data(); }
                        }

                        SettingsActionTile {
                            horizontal-stretch: 1;
                            label: "IMPORT JSON";
                            detail: "Restore the newest saved export.";
                            pressed => { root.import-latest-export(); }
                        }
                    }
                }
            }

            SettingsCard {
                horizontal-stretch: 1;
                height: 204px;

                VerticalBox {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    padding-left: 0px;
                    padding-right: 0px;
                    spacing: 10px;

                    SettingsInfoCard {
                        horizontal-stretch: 1;
                        label: "LAST EXPORT";
                        value: root.last-export;
                    }

                    SettingsActionTile {
                        horizontal-stretch: 1;
                        label: "DELETE ALL DATA";
                        detail: "Delete all local app data at once.";
                        fill: #FF5A36;
                        text-color: #111111;
                        pressed => { root.reset-all-data(); }
                    }
                }
            }

            SettingsCard {
                horizontal-stretch: 1;
                height: 152px;

                VerticalBox {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    padding-left: 0px;
                    padding-right: 0px;
                    spacing: 10px;

                    SettingsInfoCard {
                        horizontal-stretch: 1;
                        label: "PRIVACY";
                        value: "All data stays on this device unless you export it.";
                    }
                }
            }

            SettingsCard {
                horizontal-stretch: 1;
                height: 188px;

                VerticalBox {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    padding-left: 0px;
                    padding-right: 0px;
                    spacing: 8px;

                    SettingsInfoCard {
                        horizontal-stretch: 1;
                        label: "APP VERSION";
                        value: root.app-version + " | SCHEMA " + root.schema-version;
                    }

                    SettingsInfoCard {
                        horizontal-stretch: 1;
                        label: "SYSTEM";
                        value: "Open source app. No account required.";
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                height: 120px;
                background: transparent;

                ActionButton {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: 54px;
                    label: "SAVE ALL CHANGES";
                    clicked => { root.save-settings(); }
                }

                HorizontalBox {
                    x: 0;
                    y: 66px;
                    width: parent.width;
                    height: 54px;
                    padding: 0;
                    spacing: 10px;

                    ActionButton {
                        horizontal-stretch: 1;
                        label: "RESET COLORS";
                        outlined: true;
                        clicked => { root.reset-colors(); }
                    }

                    ActionButton {
                        horizontal-stretch: 1;
                        label: "RESET DEFAULTS";
                        outlined: true;
                        clicked => { root.reset-defaults(); }
                    }
                }
            }
        }
    }
}
