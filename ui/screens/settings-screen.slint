import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { UiVars } from "../theme.slint";
import { Panel, SectionLabel, SmallNote, ActionButton, BrutalistDropdown } from "../components.slint";

component SettingsField inherits Rectangle {
    in property <string> label;
    in-out property <string> value;
    in property <string> placeholder: "";

    height: 68px;
    background: transparent;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        padding: 0;
        spacing: 6px;

        SmallNote { text: root.label; }

        Rectangle {
            horizontal-stretch: 1;
            height: 42px;
            background: input.has-focus ? UiVars.surface-strong : transparent;
            border-color: input.has-focus ? UiVars.accent : UiVars.ink;
            border-width: UiVars.border-width;

            input := TextInput {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text <=> root.value;
                color: UiVars.ink;
                font-size: 13px;
                font-weight: 800;
                vertical-alignment: center;
                single-line: true;
            }

            if root.value == "" : Text {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text: root.placeholder;
                color: UiVars.ink-muted;
                font-size: 13px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }
    }
}

component SettingsDropdownField inherits Rectangle {
    in property <string> label;
    in property <[string]> model;
    in-out property <string> value;

    height: 68px;
    background: transparent;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        padding: 0;
        spacing: 6px;

        SmallNote { text: root.label; }

        BrutalistDropdown {
            horizontal-stretch: 1;
            model: root.model;
            current-value <=> root.value;
        }
    }
}

component SettingsInfoRow inherits Rectangle {
    in property <string> text;
    in property <color> tone: UiVars.ink-soft;

    height: 18px;
    background: transparent;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: root.tone;
        font-size: UiVars.note-size;
        font-weight: 600;
        letter-spacing: 1px;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component SettingsScreen inherits Rectangle {
    in-out property <string> accent-color;
    in-out property <string> background-color;
    in-out property <string> text-color;
    in-out property <string> default-rest;
    in-out property <string> weight-unit;
    in-out property <string> set-count;
    in-out property <string> rep-target;
    in property <string> storage-path;
    in property <string> database-path;
    in property <string> settings-path;
    in property <string> last-export;
    in property <string> last-backup;
    in property <string> app-version;
    in property <string> schema-version;

    callback save-settings;
    callback reset-colors;
    callback reset-defaults;
    callback export-all-data;
    callback import-latest-export;
    callback create-backup;
    callback restore-latest-backup;
    callback clear-history;
    callback clear-templates;
    callback clear-custom-exercises;
    callback reset-all-data;

    property <bool> appearance-expanded: true;
    property <bool> defaults-expanded: true;
    property <bool> data-expanded: false;
    property <bool> privacy-expanded: false;
    property <bool> info-expanded: false;

    background: UiVars.screen-bg;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            alignment: start;
            padding-top: UiVars.page-padding;
            padding-left: root.width > 720px ? (root.width - 640px) / 2 : UiVars.page-padding;
            padding-right: root.width > 720px ? (root.width - 640px) / 2 : UiVars.page-padding;
            padding-bottom: 28px;
            spacing: 14px;

            SectionLabel { text: "SETTINGS"; }

            Panel {
                horizontal-stretch: 1;
                height: root.appearance-expanded ? 320px : 58px;

                Rectangle {
                    x: UiVars.page-padding;
                    y: UiVars.page-padding;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: 30px;
                    background: transparent;

                    Text {
                        width: parent.width - 34px;
                        height: parent.height;
                        text: "APPEARANCE";
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        text: root.appearance-expanded ? "−" : "+";
                        color: UiVars.ink;
                        font-size: 18px;
                        font-weight: 900;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea { clicked => { root.appearance-expanded = !root.appearance-expanded; } }
                }

                if root.appearance-expanded : Rectangle {
                    x: UiVars.page-padding;
                    y: 52px;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: parent.height - 66px;
                    background: transparent;

                    VerticalBox {
                        width: parent.width;
                        height: parent.height;
                        padding: 0;
                        spacing: 12px;

                        Rectangle { height: 1px; background: UiVars.border-soft; }
                        SettingsField { horizontal-stretch: 1; label: "ACCENT COLOR"; value <=> root.accent-color; placeholder: "#F2CF00"; }
                        SettingsField { horizontal-stretch: 1; label: "BACKGROUND COLOR"; value <=> root.background-color; placeholder: "#EFEDE8"; }
                        SettingsField { horizontal-stretch: 1; label: "TEXT COLOR"; value <=> root.text-color; placeholder: "#111111"; }

                        Rectangle {
                            height: 36px;
                            HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                padding: 0;
                                spacing: 10px;

                                ActionButton { horizontal-stretch: 1; label: "SAVE COLORS"; clicked => { root.save-settings(); } }
                                ActionButton { horizontal-stretch: 1; label: "RESET COLORS"; outlined: true; clicked => { root.reset-colors(); } }
                            }
                        }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                height: root.defaults-expanded ? 402px : 58px;

                Rectangle {
                    x: UiVars.page-padding;
                    y: UiVars.page-padding;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: 30px;
                    background: transparent;

                    Text {
                        width: parent.width - 34px;
                        height: parent.height;
                        text: "DEFAULTS";
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        text: root.defaults-expanded ? "−" : "+";
                        color: UiVars.ink;
                        font-size: 18px;
                        font-weight: 900;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea { clicked => { root.defaults-expanded = !root.defaults-expanded; } }
                }

                if root.defaults-expanded : Rectangle {
                    x: UiVars.page-padding;
                    y: 52px;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: parent.height - 66px;
                    background: transparent;

                    VerticalBox {
                        width: parent.width;
                        height: parent.height;
                        padding: 0;
                        spacing: 12px;

                        Rectangle { height: 1px; background: UiVars.border-soft; }
                        SettingsField { horizontal-stretch: 1; label: "REST TIME (SECONDS)"; value <=> root.default-rest; placeholder: "90"; }
                        SettingsField { horizontal-stretch: 1; label: "SET COUNT"; value <=> root.set-count; placeholder: "3"; }
                        SettingsField { horizontal-stretch: 1; label: "REP TARGET"; value <=> root.rep-target; placeholder: "8"; }
                        SettingsDropdownField { horizontal-stretch: 1; label: "WEIGHT UNIT"; model: ["Kg", "Lbs"]; value <=> root.weight-unit; }

                        Rectangle {
                            height: 36px;
                            HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                padding: 0;
                                spacing: 10px;

                                ActionButton { horizontal-stretch: 1; label: "SAVE DEFAULTS"; clicked => { root.save-settings(); } }
                                ActionButton { horizontal-stretch: 1; label: "RESET DEFAULTS"; outlined: true; clicked => { root.reset-defaults(); } }
                            }
                        }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                height: root.data-expanded ? 440px : 58px;

                Rectangle {
                    x: UiVars.page-padding;
                    y: UiVars.page-padding;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: 30px;
                    background: transparent;

                    Text {
                        width: parent.width - 34px;
                        height: parent.height;
                        text: "DATA";
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        text: root.data-expanded ? "−" : "+";
                        color: UiVars.ink;
                        font-size: 18px;
                        font-weight: 900;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea { clicked => { root.data-expanded = !root.data-expanded; } }
                }

                if root.data-expanded : Rectangle {
                    x: UiVars.page-padding;
                    y: 52px;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: parent.height - 66px;
                    background: transparent;

                    VerticalBox {
                        width: parent.width;
                        height: parent.height;
                        padding: 0;
                        spacing: 10px;

                        Rectangle { height: 1px; background: UiVars.border-soft; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "LAST EXPORT: " + root.last-export; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "LAST BACKUP: " + root.last-backup; }
                        ActionButton { horizontal-stretch: 1; height: 36px; label: "EXPORT ALL DATA"; clicked => { root.export-all-data(); } }
                        ActionButton { horizontal-stretch: 1; height: 36px; label: "IMPORT LATEST EXPORT"; outlined: true; clicked => { root.import-latest-export(); } }
                        ActionButton { horizontal-stretch: 1; height: 36px; label: "CREATE BACKUP"; clicked => { root.create-backup(); } }
                        ActionButton { horizontal-stretch: 1; height: 36px; label: "RESTORE BACKUP"; outlined: true; clicked => { root.restore-latest-backup(); } }

                        Rectangle {
                            height: 36px;
                            HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                padding: 0;
                                spacing: 10px;

                                ActionButton { horizontal-stretch: 1; label: "DELETE HISTORY"; outlined: true; clicked => { root.clear-history(); } }
                                ActionButton { horizontal-stretch: 1; label: "DELETE TEMPLATES"; outlined: true; clicked => { root.clear-templates(); } }
                            }
                        }

                        ActionButton { horizontal-stretch: 1; height: 36px; label: "DELETE CUSTOM EXERCISES"; outlined: true; clicked => { root.clear-custom-exercises(); } }
                        ActionButton { horizontal-stretch: 1; height: 36px; label: "RESET ALL DATA"; fill: UiVars.danger; text-color: UiVars.surface; clicked => { root.reset-all-data(); } }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                height: root.privacy-expanded ? 166px : 58px;

                Rectangle {
                    x: UiVars.page-padding;
                    y: UiVars.page-padding;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: 30px;
                    background: transparent;

                    Text {
                        width: parent.width - 34px;
                        height: parent.height;
                        text: "PRIVACY";
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        text: root.privacy-expanded ? "−" : "+";
                        color: UiVars.ink;
                        font-size: 18px;
                        font-weight: 900;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea { clicked => { root.privacy-expanded = !root.privacy-expanded; } }
                }

                if root.privacy-expanded : Rectangle {
                    x: UiVars.page-padding;
                    y: 52px;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: parent.height - 66px;
                    background: transparent;

                    VerticalBox {
                        width: parent.width;
                        height: parent.height;
                        padding: 0;
                        spacing: 8px;

                        Rectangle { height: 1px; background: UiVars.border-soft; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "ALL DATA STAYS ON THIS DEVICE UNLESS YOU EXPORT IT MANUALLY."; tone: UiVars.ink; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "STORAGE PATH: " + root.storage-path; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "DATABASE PATH: " + root.database-path; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "SETTINGS FILE: " + root.settings-path; }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                height: root.info-expanded ? 128px : 58px;

                Rectangle {
                    x: UiVars.page-padding;
                    y: UiVars.page-padding;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: 30px;
                    background: transparent;

                    Text {
                        width: parent.width - 34px;
                        height: parent.height;
                        text: "INFO";
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width - 24px;
                        width: 24px;
                        height: parent.height;
                        text: root.info-expanded ? "−" : "+";
                        color: UiVars.ink;
                        font-size: 18px;
                        font-weight: 900;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea { clicked => { root.info-expanded = !root.info-expanded; } }
                }

                if root.info-expanded : Rectangle {
                    x: UiVars.page-padding;
                    y: 52px;
                    width: parent.width - (UiVars.page-padding * 2);
                    height: parent.height - 66px;
                    background: transparent;

                    VerticalBox {
                        width: parent.width;
                        height: parent.height;
                        padding: 0;
                        spacing: 8px;

                        Rectangle { height: 1px; background: UiVars.border-soft; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "APP VERSION: " + root.app-version; tone: UiVars.ink; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "SCHEMA VERSION: " + root.schema-version; }
                        SettingsInfoRow { horizontal-stretch: 1; text: "OPEN SOURCE APP | NO LOGIN REQUIRED"; }
                    }
                }
            }
        }
    }
}
