import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { UiVars } from "../theme.slint";
import { Panel, SectionLabel, SmallNote, ActionButton, BrutalistDropdown } from "../components.slint";

component SettingsField inherits Rectangle {
    in property <string> label;
    in-out property <string> value;
    in property <string> placeholder: "";

    height: 68px;
    background: transparent;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        padding: 0;
        spacing: 6px;

        SmallNote { text: root.label; }

        Rectangle {
            horizontal-stretch: 1;
            height: 42px;
            background: input.has-focus ? UiVars.surface-strong : transparent;
            border-color: input.has-focus ? UiVars.accent : UiVars.ink;
            border-width: UiVars.border-width;

            input := TextInput {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text <=> root.value;
                color: UiVars.ink;
                font-size: 13px;
                font-weight: 800;
                vertical-alignment: center;
                single-line: true;
            }

            if root.value == "" : Text {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text: root.placeholder;
                color: UiVars.ink-muted;
                font-size: 13px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }
    }
}

component SettingsDropdownField inherits Rectangle {
    in property <string> label;
    in property <[string]> model;
    in-out property <string> value;

    height: 68px;
    background: transparent;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        padding: 0;
        spacing: 6px;

        SmallNote { text: root.label; }

        BrutalistDropdown {
            horizontal-stretch: 1;
            model: root.model;
            current-value <=> root.value;
        }
    }
}

component SettingsInfoRow inherits Rectangle {
    in property <string> text;
    in property <color> tone: UiVars.ink-soft;

    height: 18px;
    background: transparent;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: root.tone;
        font-size: UiVars.note-size;
        font-weight: 600;
        letter-spacing: 1px;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component SettingsScreen inherits Rectangle {
    in-out property <string> accent-color;
    in-out property <string> background-color;
    in-out property <string> text-color;
    in-out property <string> default-rest;
    in-out property <string> weight-unit;
    in-out property <string> set-count;
    in-out property <string> rep-target;
    in property <string> storage-path;
    in property <string> database-path;
    in property <string> settings-path;
    in property <string> last-export;
    in property <string> last-backup;
    in property <string> app-version;
    in property <string> schema-version;

    callback save-settings;
    callback reset-colors;
    callback reset-defaults;
    callback export-all-data;
    callback import-latest-export;
    callback create-backup;
    callback restore-latest-backup;
    callback clear-history;
    callback clear-templates;
    callback clear-custom-exercises;
    callback reset-all-data;

    background: UiVars.screen-bg;

    ScrollView {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            alignment: start;
            padding-left: UiVars.page-padding;
            padding-right: UiVars.page-padding;
            padding-bottom: 28px;
            spacing: 0;

            SectionLabel { text: "SETTINGS"; }
            Rectangle { height: UiVars.section-title-gap; }
            SmallNote {
                horizontal-stretch: 1;
                text: "Customize colors, defaults, local data management and app info.";
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "APPEARANCE"; }
            Rectangle { height: UiVars.section-title-gap; }
            SmallNote {
                horizontal-stretch: 1;
                text: "Set accent, background and text colors with hex values.";
            }
            Rectangle { height: UiVars.block-gap; }

            Panel {
                horizontal-stretch: 1;
                height: 292px;

                VerticalBox {
                    width: parent.width;
                    height: parent.height;
                    padding: UiVars.page-padding;
                    spacing: UiVars.block-gap;

                    Rectangle {
                        height: 68px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            SettingsField {
                                horizontal-stretch: 1;
                                label: "ACCENT COLOR";
                                value <=> root.accent-color;
                                placeholder: "#F2CF00";
                            }

                            SettingsField {
                                horizontal-stretch: 1;
                                label: "BACKGROUND COLOR";
                                value <=> root.background-color;
                                placeholder: "#EFEDE8";
                            }
                        }
                    }

                    SettingsField {
                        horizontal-stretch: 1;
                        label: "TEXT COLOR";
                        value <=> root.text-color;
                        placeholder: "#111111";
                    }

                    Panel {
                        horizontal-stretch: 1;
                        height: 56px;
                        fill: UiVars.accent;

                        Text {
                            x: 12px;
                            y: 8px;
                            text: "LIVE PREVIEW";
                            color: UiVars.ink;
                            font-size: 12px;
                            font-weight: 900;
                            letter-spacing: 1px;
                        }

                        SmallNote {
                            x: 12px;
                            y: 28px;
                            width: parent.width - 24px;
                            text: "Saved colors update the full app theme.";
                            color: UiVars.ink;
                        }
                    }

                    Rectangle {
                        height: 36px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "SAVE COLORS";
                                clicked => { root.save-settings(); }
                            }

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "RESET COLORS";
                                outlined: true;
                                clicked => { root.reset-colors(); }
                            }
                        }
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "DEFAULTS"; }
            Rectangle { height: UiVars.section-title-gap; }
            SmallNote {
                horizontal-stretch: 1;
                text: "These values are used when creating new workout drafts.";
            }
            Rectangle { height: UiVars.block-gap; }

            Panel {
                horizontal-stretch: 1;
                height: 224px;

                VerticalBox {
                    width: parent.width;
                    height: parent.height;
                    padding: UiVars.page-padding;
                    spacing: UiVars.block-gap;

                    Rectangle {
                        height: 68px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            SettingsField {
                                horizontal-stretch: 1;
                                label: "REST TIME (SECONDS)";
                                value <=> root.default-rest;
                                placeholder: "90";
                            }

                            SettingsField {
                                horizontal-stretch: 1;
                                label: "SET COUNT";
                                value <=> root.set-count;
                                placeholder: "3";
                            }
                        }
                    }

                    Rectangle {
                        height: 68px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            SettingsField {
                                horizontal-stretch: 1;
                                label: "REP TARGET";
                                value <=> root.rep-target;
                                placeholder: "8";
                            }

                            SettingsDropdownField {
                                horizontal-stretch: 1;
                                label: "WEIGHT UNIT";
                                model: ["Kg", "Lbs"];
                                value <=> root.weight-unit;
                            }
                        }
                    }

                    Rectangle {
                        height: 36px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "SAVE DEFAULTS";
                                clicked => { root.save-settings(); }
                            }

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "RESET DEFAULTS";
                                outlined: true;
                                clicked => { root.reset-defaults(); }
                            }
                        }
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "DATA"; }
            Rectangle { height: UiVars.section-title-gap; }
            SmallNote {
                horizontal-stretch: 1;
                text: "Export, import, create backups and clear local data.";
            }
            Rectangle { height: UiVars.block-gap; }

            Panel {
                horizontal-stretch: 1;
                height: 268px;

                VerticalBox {
                    width: parent.width;
                    height: parent.height;
                    padding: UiVars.page-padding;
                    spacing: UiVars.block-gap;

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "LAST EXPORT: " + root.last-export;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "LAST BACKUP: " + root.last-backup;
                    }

                    Rectangle {
                        height: 36px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "EXPORT ALL DATA";
                                clicked => { root.export-all-data(); }
                            }

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "IMPORT LATEST EXPORT";
                                outlined: true;
                                clicked => { root.import-latest-export(); }
                            }
                        }
                    }

                    Rectangle {
                        height: 36px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "CREATE BACKUP";
                                clicked => { root.create-backup(); }
                            }

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "RESTORE BACKUP";
                                outlined: true;
                                clicked => { root.restore-latest-backup(); }
                            }
                        }
                    }

                    Rectangle {
                        height: 36px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "DELETE HISTORY";
                                outlined: true;
                                clicked => { root.clear-history(); }
                            }

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "DELETE TEMPLATES";
                                outlined: true;
                                clicked => { root.clear-templates(); }
                            }
                        }
                    }

                    Rectangle {
                        height: 36px;
                        horizontal-stretch: 1;

                        HorizontalBox {
                            width: parent.width;
                            height: parent.height;
                            padding: 0;
                            spacing: 10px;

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "DELETE CUSTOM EXERCISES";
                                outlined: true;
                                clicked => { root.clear-custom-exercises(); }
                            }

                            ActionButton {
                                horizontal-stretch: 1;
                                label: "RESET ALL DATA";
                                fill: UiVars.danger;
                                text-color: UiVars.surface;
                                clicked => { root.reset-all-data(); }
                            }
                        }
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "PRIVACY"; }
            Rectangle { height: UiVars.section-title-gap; }
            SmallNote {
                horizontal-stretch: 1;
                text: "This app is local-first and needs no account.";
            }
            Rectangle { height: UiVars.block-gap; }

            Panel {
                horizontal-stretch: 1;
                height: 150px;

                VerticalBox {
                    width: parent.width;
                    height: parent.height;
                    padding: UiVars.page-padding;
                    spacing: 8px;

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "ALL DATA STAYS ON THIS DEVICE UNLESS YOU EXPORT IT MANUALLY.";
                        tone: UiVars.ink;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "STORAGE PATH: " + root.storage-path;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "DATABASE PATH: " + root.database-path;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "SETTINGS FILE: " + root.settings-path;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "STORED LOCALLY: TEMPLATES, SESSIONS, PRS, EXERCISES AND SETTINGS.";
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            SectionLabel { text: "INFO"; }
            Rectangle { height: UiVars.section-title-gap; }
            SmallNote {
                horizontal-stretch: 1;
                text: "Build and schema metadata for this local installation.";
            }
            Rectangle { height: UiVars.block-gap; }

            Panel {
                horizontal-stretch: 1;
                height: 104px;

                VerticalBox {
                    width: parent.width;
                    height: parent.height;
                    padding: UiVars.page-padding;
                    spacing: 8px;

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "APP VERSION: " + root.app-version;
                        tone: UiVars.ink;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "SCHEMA VERSION: " + root.schema-version;
                    }

                    SettingsInfoRow {
                        horizontal-stretch: 1;
                        text: "OPEN SOURCE APP | NO LOGIN REQUIRED";
                    }
                }
            }
        }
    }
}
