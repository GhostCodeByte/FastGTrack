import { ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { SessionCard, StatsCalendarDay, StatsExerciseRow, StatsPrRow, StatsPlanRow } from "../types.slint";
import { UiVars } from "../theme.slint";
import { Panel, SectionLabel, SmallNote, BrutalistDropdown } from "../components.slint";
import { DynamicIcon } from "../generated_icons.slint";

export component StatsScreen inherits Rectangle {
    in property <[SessionCard]> history: [];
    in property <int> workouts-this-month: 0;
    in property <int> new-prs: 0;
    in property <string> calendar-month-label: "MARCH 2026";
    in property <int> calendar-first-weekday: 0;
    in property <int> calendar-days-in-month: 31;
    in property <[StatsCalendarDay]> calendar-days: [];
    in property <[StatsExerciseRow]> top-exercises: [];
    in property <[StatsPrRow]> pr-progression: [];
    in property <[StatsPlanRow]> plan-rows: [];
    in-out property <string> selected-period: "LAST 30 DAYS";

    callback period-changed();

    background: UiVars.screen-bg;

    // ── Fixed period selector at top ────────────────────────────────
    Rectangle {
        x: UiVars.page-padding;
        y: 0;
        width: parent.width - UiVars.page-padding * 2;
        height: 56px;
        z: 50;

        Text {
            x: 0;
            y: 4px;
            text: "PERIODE";
            color: UiVars.ink-muted;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1.5px;
        }

        BrutalistDropdown {
            y: 16px;
            width: parent.width;
            model: ["LAST 7 DAYS", "LAST 30 DAYS", "LAST 365 DAYS", "ALL TIME"];
            current-value <=> root.selected-period;
            changed => {
                root.period-changed();
            }
        }
    }

    // ── Scrollable content ──────────────────────────────────────────
    ScrollView {
        x: 0;
        y: 56px;
        width: parent.width;
        height: parent.height - 56px;

        VerticalBox {
            alignment: start;
            padding-left: UiVars.page-padding;
            padding-right: UiVars.page-padding;
            spacing: 0;

            // ── HISTORY ────────────────────────────────────────────────
            SectionLabel { text: "HISTORY"; }
            Rectangle { height: UiVars.section-title-gap; }

            if root.history.length == 0 : Panel {
                horizontal-stretch: 1;
                height: 54px;
                Text {
                    x: 14px;
                    text: "NO DATA YET. FINISH AT LEAST ONE WORKOUT.";
                    color: UiVars.ink-muted;
                    font-size: 11px;
                    font-weight: 700;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                    height: parent.height;
                }
            }

            for session in root.history : Rectangle {
                horizontal-stretch: 1;
                height: 62px;

                Panel {
                    width: parent.width;
                    height: 54px;

                    if session.icon != "" : Rectangle {
                        x: 10px;
                        y: 10px;
                        width: 26px;
                        height: 26px;
                        background: UiVars.panel-bg-soft;
                        border-color: UiVars.quiet-stroke;
                        border-width: 1px;

                        DynamicIcon {
                            width: 26px;
                            height: 26px;
                            x: (parent.width - 26px) / 2;
                            y: (parent.height - 26px) / 2;
                            icon-name: session.icon;
                        }
                    }

                    Text {
                        x: session.icon != "" ? 46px : 14px;
                        y: 10px;
                        width: parent.width - (session.icon != "" ? 84px : 52px);
                        text: session.title;
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 800;
                        overflow: elide;
                    }

                    Text {
                        x: session.icon != "" ? 46px : 14px;
                        y: 28px;
                        width: parent.width - (session.icon != "" ? 84px : 52px);
                        text: session.subtitle;
                        color: UiVars.ink-muted;
                        font-size: 9px;
                        font-weight: 700;
                        letter-spacing: 0.8px;
                        overflow: elide;
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            // ── WORKOUTS / MONTH + NEW PRs ──────────────────────────
            HorizontalBox {
                horizontal-stretch: 1;
                spacing: 12px;
                padding: 0;
                height: 108px;

                Panel {
                    horizontal-stretch: 1;
                    fill: UiVars.accent;

                    Text {
                        x: 16px;
                        y: 12px;
                        text: "WORKOUTS / MONTH";
                        color: UiVars.ink;
                        font-size: 9px;
                        font-weight: 800;
                        letter-spacing: 1.5px;
                    }
                    Text {
                        x: 16px;
                        y: 28px;
                        text: root.workouts-this-month;
                        color: UiVars.ink;
                        font-size: 36px;
                        font-weight: 900;
                    }
                    Text {
                        x: 16px;
                        y: 74px;
                        text: root.workouts-this-month >= 12 ? "On Track" : root.workouts-this-month >= 4 ? "Building" : "Getting Started";
                        color: UiVars.ink;
                        font-size: 10px;
                        font-weight: 700;
                    }
                }

                Panel {
                    horizontal-stretch: 1;

                    Text {
                        x: 16px;
                        y: 12px;
                        text: "NEW PRS";
                        color: UiVars.ink;
                        font-size: 9px;
                        font-weight: 800;
                        letter-spacing: 1.5px;
                    }
                    Text {
                        x: 16px;
                        y: 28px;
                        text: root.new-prs < 10 ? "0" + root.new-prs : root.new-prs;
                        color: UiVars.ink;
                        font-size: 36px;
                        font-weight: 900;
                    }
                    // PR rating dots (font-safe)
                    HorizontalBox {
                        x: 16px;
                        y: 74px;
                        width: parent.width - 32px;
                        height: 16px;
                        spacing: 4px;
                        padding: 0;

                        for i in [0, 1, 2, 3, 4] : Rectangle {
                            width: 14px;
                            height: 14px;
                            background: i < root.new-prs ? UiVars.accent : transparent;
                            border-color: UiVars.ink;
                            border-width: UiVars.border-width;
                        }
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            // ── CALENDAR ───────────────────────────────────────────────
            SectionLabel { text: root.calendar-month-label; }
            Rectangle { height: UiVars.section-title-gap; }

            Panel {
                horizontal-stretch: 1;
                property <length> cell-pad: 10px;
                property <length> cell-gap: 4px;
                property <length> cell-size: (self.width - 2 * cell-pad - 6 * cell-gap) / 7;

                property <int> total-cells: root.calendar-first-weekday + root.calendar-days-in-month;
                property <int> grid-rows: total-cells <= 28 ? 4 : total-cells <= 35 ? 5 : 6;
                height: cell-pad + 20px + 4px + grid-rows * (cell-size + cell-gap) + cell-pad;

                // Weekday headers
                for label[idx] in ["S", "M", "T", "W", "T", "F", "S"] : Text {
                    x: parent.cell-pad + idx * (parent.cell-size + parent.cell-gap);
                    y: parent.cell-pad;
                    width: parent.cell-size;
                    height: 20px;
                    text: label;
                    color: UiVars.ink-muted;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 1px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                // Day cells
                for day in root.calendar-days : Rectangle {
                    property <int> slot: root.calendar-first-weekday + day.day - 1;
                    property <int> grid-col: Math.mod(slot, 7);
                    property <int> grid-row: Math.floor(slot / 7);

                    x: parent.cell-pad + grid-col * (parent.cell-size + parent.cell-gap);
                    y: parent.cell-pad + 20px + 4px + grid-row * (parent.cell-size + parent.cell-gap);
                    width: parent.cell-size;
                    height: parent.cell-size;
                    background: day.active ? UiVars.accent : UiVars.screen-bg;
                    border-color: day.is-today ? UiVars.ink : day.active ? UiVars.ink : UiVars.border-soft;
                    border-width: day.is-today ? UiVars.border-width : 1px;

                    Text {
                        text: day.day;
                        color: day.active ? UiVars.ink : UiVars.ink-muted;
                        font-size: 11px;
                        font-weight: day.active ? 800 : 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            // ── EXERCISES ───────────────────────────────────────────────
            SectionLabel { text: "EXERCISES"; }
            Rectangle { height: UiVars.section-title-gap; }

            if root.top-exercises.length == 0 : SmallNote {
                text: "COMPLETE WORKOUTS TO SEE TOP EXERCISES";
            }

            for exercise in root.top-exercises : Rectangle {
                horizontal-stretch: 1;
                height: 52px;

                Panel {
                    width: parent.width;
                    height: 44px;

                    Text {
                        x: 14px;
                        text: exercise.name;
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        height: parent.height;
                        width: parent.width - 80px;
                        overflow: elide;
                    }

                    Rectangle {
                        x: parent.width - 64px;
                        y: (parent.height - 28px) / 2;
                        width: 50px;
                        height: 28px;
                        background: UiVars.accent;
                        border-color: UiVars.ink;
                        border-width: UiVars.border-width;

                        Text {
                            text: exercise.count-label;
                            color: UiVars.ink;
                            font-size: 11px;
                            font-weight: 900;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
            }

            if root.top-exercises.length > 0 : SmallNote {
                text: "ALL RECORDED EXERCISES (TOP " + root.top-exercises.length + ")";
                horizontal-alignment: center;
            }

            Rectangle { height: UiVars.section-gap; }

            // ── PR PROGRESSION ───────────────────────────────────────────
            SectionLabel { text: "PR PROGRESSION"; }
            Rectangle { height: UiVars.section-title-gap; }

            if root.pr-progression.length == 0 : SmallNote {
                text: "SET NEW PERSONAL RECORDS TO TRACK PROGRESSION";
            }

            for pr in root.pr-progression : Rectangle {
                horizontal-stretch: 1;
                height: 68px;

                Panel {
                    width: parent.width;
                    height: 60px;

                    Text {
                        x: 14px;
                        y: 10px;
                        text: pr.name;
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 800;
                        width: parent.width - 100px;
                        overflow: elide;
                    }

                    Text {
                        x: 14px;
                        y: 32px;
                        text: "Last: " + pr.last-weight;
                        color: UiVars.ink-muted;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                    }

                    Text {
                        x: parent.width - 90px;
                        y: 10px;
                        width: 76px;
                        text: pr.current-weight;
                        color: UiVars.ink;
                        font-size: 20px;
                        font-weight: 900;
                        horizontal-alignment: right;
                    }

                    Text {
                        x: parent.width - 90px;
                        y: 36px;
                        width: 76px;
                        text: pr.trend;
                        color: UiVars.accent-deep;
                        font-size: 10px;
                        font-weight: 800;
                        horizontal-alignment: right;
                        letter-spacing: 0.5px;
                    }
                }
            }

            Rectangle { height: UiVars.section-gap; }

            // ── PLAN ───────────────────────────────────────────────────
            SectionLabel { text: "PLAN"; }
            Rectangle { height: UiVars.section-title-gap; }

            if root.plan-rows.length == 0 : SmallNote {
                text: "CREATE TEMPLATES AND TRACK SESSIONS";
            }

            for plan in root.plan-rows : Rectangle {
                horizontal-stretch: 1;
                height: 50px;

                Panel {
                    width: parent.width;
                    height: 42px;

                    Text {
                        x: 14px;
                        text: plan.name;
                        color: UiVars.ink;
                        font-size: 12px;
                        font-weight: 800;
                        vertical-alignment: center;
                        height: parent.height;
                        width: parent.width - 120px;
                        overflow: elide;
                    }

                    Text {
                        x: parent.width - 110px;
                        width: 96px;
                        text: plan.session-count;
                        color: UiVars.ink-muted;
                        font-size: 11px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        height: parent.height;
                    }
                }
            }

            Rectangle { height: 10px; }
        }
    }
}
