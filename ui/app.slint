

import { ExerciseRow, TemplateCard, SessionCard, ScheduleCard, DraftExerciseRow, WorkoutExerciseRow, WorkoutSetRow, WeekdayProgress, StatsCalendarDay, StatsExerciseRow, StatsPrRow, StatsPlanRow } from "types.slint";
export { ExerciseRow, TemplateCard, SessionCard, ScheduleCard, DraftExerciseRow, WorkoutExerciseRow, WorkoutSetRow, WeekdayProgress, StatsCalendarDay, StatsExerciseRow, StatsPrRow, StatsPlanRow }

import { UiVars } from "theme.slint";
export { UiVars }

import { NavItem } from "components.slint";
import { HomeScreen } from "screens/home-screen.slint";
import { ExerciseScreen } from "screens/exercise-screen.slint";
import { PlannerScreen } from "screens/planner-screen.slint";
import { WorkoutScreen } from "screens/workout-screen.slint";
import { StatsScreen } from "screens/stats-screen.slint";
import { SettingsScreen } from "screens/settings-screen.slint";

import "./fonts/Sora.ttf";

import { Panel } from "components.slint";

/// The root UI window component that orchestrates all sub-screens, persistent navigation, 
/// and top-level state synchronization with the Rust backend.
export component MainWindow inherits Window {
    title: "FastGTrack";
    default-font-family: "Sora";
    background: UiVars.screen-bg;
    min-width: 360px;
    min-height: 760px;

    /// Controls which main tab is currently rendered (0=Home, 1=Exercises, 2=Planner (hidden), 3=Stats, 4=Settings).
    in-out property <int> selected-tab: 0;
    /// A toggle flag used by timers to animate components globally across the app.
    in-out property <bool> animation-tick: false;

    Timer {
        interval: 1000ms;
        running: root.has-active-workout || root.active-rest-timer > 0;
        triggered => {
            root.animation-tick = !root.animation-tick;
            if (root.active-rest-timer > 0) {
                root.active-rest-timer -= 1;
            }
        }
    }

    /// Fetched array data models injected from the Rust backend.
    in property <[ExerciseRow]> exercises: [];
    in property <[TemplateCard]> templates: [];
    in property <[SessionCard]> recent-sessions: [];
    in property <[ScheduleCard]> schedule: [];
    in property <[DraftExerciseRow]> draft-exercises: [];
    in property <[WorkoutExerciseRow]> workout-exercises: [];
    in property <[WorkoutSetRow]> workout-sets: [];
    in property <[WeekdayProgress]> week-progress: [];

    // ── Stats properties ──────────────────────────────────────────
    /// Properties passed into the application to render historical performance visualizations.
    in property <[SessionCard]> stats-history: [];
    in property <int> stats-workouts-month: 0;
    in property <int> stats-new-prs: 0;
    in property <string> stats-calendar-month-label: "";
    in property <int> stats-calendar-first-weekday: 0;
    in property <int> stats-calendar-days-in-month: 31;
    in property <[StatsCalendarDay]> stats-calendar-days: [];
    in property <[StatsExerciseRow]> stats-top-exercises: [];
    in property <[StatsPrRow]> stats-pr-progression: [];
    in property <[StatsPlanRow]> stats-plan-rows: [];
    in-out property <string> stats-period: "LAST 30 DAYS";

    /// Runtime text state indicating workout tracking and app alerts.
    in property <string> active-workout-title: "No active workout";
    in property <string> active-workout-subtitle: "Start a template from Home to enter session mode.";
    in property <string> current-exercise-title: "No exercise selected";
    in property <string> current-exercise-description: "";
    in property <string> previous-exercise-title: "-";
    in property <string> next-exercise-title: "-";
    in property <string> workout-progress: "0 / 0 sets complete";
    in property <string> rest-hint: "Rest timer adopts the template rest after every completed set.";
    in property <string> status-message: "";
    in property <string> home-hero-title: "Built for structured gym tracking";
    in property <string> home-hero-subtitle: "The MVP covers exercise CRUD, reusable workout templates, live session tracking with sets, and personal record detection.";
    in property <bool> home-has-plans: false;
    in property <string> next-workout-label: "No workout scheduled yet";
    in property <string> streak-label: "Streak: 0 days";
    in property <string> header-greeting: "HELLO, ATHLETE!";
    in property <string> header-motto: "PUSH YOUR LIMITS TODAY";
    in property <string> header-date: "MAR 10";
    in property <int> featured-template-id: -1;
    in property <string> featured-template-name: "BUILD YOUR FIRST TEMPLATE";
    in property <string> featured-template-icon: "chest";
    in property <string> featured-template-meta: "0 EXERCISES - CUSTOM SETUP";
    in property <string> featured-template-detail: "Create a clean session flow, then launch from Home.";
    in property <string> featured-template-cta: "OPEN PLANNER";
    in property <bool> has-active-workout: false;
    in-out property <int> active-rest-timer: 0;
    in property <int> active-rest-duration: 0;
    in property <int> current-exercise-index: 0;

    /// Two-way bound data models syncing user input back to the backend layer.
    in-out property <bool> is-session-fullscreen: false;
    in-out property <bool> is-search-open: false;
    in-out property <string> search-query: "";
    in-out property <string> filter-muscle: "All Muscles";
    in-out property <string> sort-by: "Most Used";
    in-out property <string> template-name: "";
    in-out property <string> template-icon: "chest";
    in-out property <[bool]> template-active-days: [false, false, false, false, false, false, false];

    in-out property <string> settings-accent-color: "#F2CF00";
    in-out property <string> settings-background-color: "#EFEDE8";
    in-out property <string> settings-text-color: "#111111";
    in-out property <string> settings-default-rest: "90";
    in-out property <string> settings-weight-unit: "Kg";
    in-out property <string> settings-set-count: "3";
    in-out property <string> settings-rep-target: "8";
    in property <string> settings-last-export: "No export yet";
    in property <string> settings-app-version: "0.0.0";
    in property <string> settings-schema-version: "1";

    private property <length> top-safe: 38px;
    private property <length> bottom-safe: 28px;

    /// Standard event hooks that bubble up to Rust for state mutation out-of-band.
    callback search-query-changed();
    callback add-draft-exercise(int, string, string, string, string, string, string, string);
    callback remove-draft-exercise(int);
    callback clear-draft();
    callback save-template(string, string, string);
    callback delete-template(int);
    callback edit-template(int);
    callback add-set(int);
    callback remove-set(int, int);
    callback update-set(int, int, string, string, string);
    callback update-set-range(int, int, int, string, string);
    callback start-workout(int);
    callback select-active-exercise(int);
    callback complete-set(int, int, string, string, string);
    callback finish-workout();
    callback add-active-set(int);
    callback stats-period-changed();
    callback save-settings();
    callback reset-colors();
    callback reset-defaults();
    callback apply-theme-live();
    callback export-all-data();
    callback import-latest-export();
    callback reset-all-data();

    dummy-focus := FocusScope {
        x: 0;
        y: 0;
        width: 0;
        height: 0;
    }

    VerticalLayout {
        padding: 0;
        spacing: 0;

        Rectangle {
            height: root.top-safe;
            background: UiVars.screen-bg;
        }

        Panel {
            height: 48px;
            border-width: UiVars.border-width;
            drop-shadow-color: UiVars.ink;
            drop-shadow-offset-x: 4px;
            drop-shadow-offset-y: 4px;
            drop-shadow-blur: 0px;

            Text {
                x: UiVars.page-padding;
                y: 6px;
                width: parent.width - 140px;
                text: root.header-greeting;
                color: UiVars.ink;
                font-size: 18px;
                font-weight: 800;
                horizontal-alignment: left;
            }
            Text {
                x: UiVars.page-padding;
                y: 29px;
                width: parent.width - 140px;
                text: root.header-motto;
                color: UiVars.ink-soft;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 1px;
                horizontal-alignment: left;
            }
            Text {
                x: parent.width - 78px;
                y: 7px;
                width: 60px;
                text: root.header-date;
                color: UiVars.ink;
                font-size: 16px;
                font-weight: 800;
                horizontal-alignment: center;
            }
            Rectangle {
                x: parent.width - 79px;
                y: 30px;
                width: 64px;
                height: 3px;
                background: UiVars.accent;
            }
        }

        // no clue why its / 2 but it has to be to be even
        Rectangle { height: UiVars.section-gap / 2; }

        Rectangle {
            vertical-stretch: 1;
            background: UiVars.screen-bg;

            if root.selected-tab == 0 : HomeScreen {
                width: parent.width;
                height: parent.height;

                featured-template-id: root.featured-template-id;
                featured-template-name: root.featured-template-name;
                featured-template-icon: root.featured-template-icon;
                featured-template-meta: root.featured-template-meta;
                featured-template-detail: root.featured-template-detail;
                featured-template-cta: root.featured-template-cta;

                templates: root.templates;
                recent-sessions: root.recent-sessions;
                week-progress: root.week-progress;
                has-plans: root.home-has-plans;

                open-planner => {
                    root.template-name = "";
                    root.template-icon = "chest";
                    root.template-active-days = [false, false, false, false, false, false, false];
                    root.clear-draft();
                    root.selected-tab = 2;
                    dummy-focus.focus();
                }

                start-workout(template-id) => {
                    root.start-workout(template-id);
                    root.is-session-fullscreen = true;
                    dummy-focus.focus();
                }

                delete-template(template-id) => {
                    root.delete-template(template-id);
                }

                edit-template(template-id) => {
                    root.edit-template(template-id);
                    root.selected-tab = 2; // Jump to planner
                    dummy-focus.focus();
                }
            }

            if root.selected-tab == 1 : ExerciseScreen {
                width: parent.width;
                height: parent.height;

                animation-tick: root.animation-tick;
                exercises: root.exercises;
                status-message: root.status-message;
            }

            if root.selected-tab == 2 : PlannerScreen {
                width: parent.width;
                height: parent.height;

                exercises: root.exercises;
                draft-exercises: root.draft-exercises;
                is-search-open <=> root.is-search-open;
                search-query <=> root.search-query;
                filter-muscle <=> root.filter-muscle;
                sort-by <=> root.sort-by;
                status-message: root.status-message;
                template-name <=> root.template-name;
                template-icon <=> root.template-icon;
                active-days <=> root.template-active-days;

                search-query-changed => {
                    root.search-query-changed();
                }

                add-draft-exercise(id, mode, sets, reps, duration, rir, rest, unit) => {
                    root.add-draft-exercise(id, mode, sets, reps, duration, rir, rest, unit);
                }

                clear-draft => {
                    root.clear-draft();
                }

                remove-draft-exercise(index) => {
                    root.remove-draft-exercise(index);
                }

                add-set(index) => {
                    root.add-set(index);
                }

                remove-set(index, set-index) => {
                    root.remove-set(index, set-index);
                }

                update-set(index, set-index, reps, weight, rest) => {
                    root.update-set(index, set-index, reps, weight, rest);
                }

                update-set-range(index, start-set-index, end-set-index, field, value) => {
                    root.update-set-range(index, start-set-index, end-set-index, field, value);
                }

                save-template(name, icon, day) => {
                    root.save-template(name, icon, day);
                    root.selected-tab = 0;
                    dummy-focus.focus();
                }
            }

            if root.selected-tab == 3 : StatsScreen {
                width: parent.width;
                height: parent.height;

                selected-period <=> root.stats-period;
                history: root.stats-history;
                workouts-this-month: root.stats-workouts-month;
                new-prs: root.stats-new-prs;
                calendar-month-label: root.stats-calendar-month-label;
                calendar-first-weekday: root.stats-calendar-first-weekday;
                calendar-days-in-month: root.stats-calendar-days-in-month;
                calendar-days: root.stats-calendar-days;
                top-exercises: root.stats-top-exercises;
                pr-progression: root.stats-pr-progression;
                plan-rows: root.stats-plan-rows;

                period-changed => {
                    root.stats-period-changed();
                }
            }

            if root.selected-tab == 4 : SettingsScreen {
                width: parent.width;
                height: parent.height;

                accent-color <=> root.settings-accent-color;
                background-color <=> root.settings-background-color;
                text-color <=> root.settings-text-color;
                default-rest <=> root.settings-default-rest;
                weight-unit <=> root.settings-weight-unit;
                set-count <=> root.settings-set-count;
                rep-target <=> root.settings-rep-target;
                last-export: root.settings-last-export;
                app-version: root.settings-app-version;
                schema-version: root.settings-schema-version;

                save-settings => { root.save-settings(); }
                reset-colors => { root.reset-colors(); }
                reset-defaults => { root.reset-defaults(); }
                apply-theme-live => { root.apply-theme-live(); }
                export-all-data => { root.export-all-data(); }
                import-latest-export => { root.import-latest-export(); }
                reset-all-data => { root.reset-all-data(); }
            }
        }

        if root.has-active-workout && !root.is-session-fullscreen : Rectangle {
            height: 48px;
            background: UiVars.accent;

            Rectangle {
                x: 0;
                y: 0;
                height: parent.height;
                width: root.active-rest-duration > 0 ? parent.width * root.active-rest-timer / root.active-rest-duration : 0;
                background: UiVars.accent-deep;
            }

            Rectangle {
                y: 0;
                width: parent.width;
                height: 2px;
                background: UiVars.ink;
            }

            Text {
                x: 14px;
                text: "ACTIVE SESSION: " + root.active-workout-title;
                color: UiVars.ink;
                font-weight: 800;
                font-size: 12px;
                vertical-alignment: center;
                height: parent.height;
                overflow: elide;
                width: parent.width - 80px;
            }

            if root.active-rest-timer > 0 : Text {
                x: parent.width - 60px;
                width: 46px;
                horizontal-alignment: right;
                text: root.active-rest-timer + "s";
                color: UiVars.ink;
                font-weight: 800;
                font-size: 14px;
                vertical-alignment: center;
                height: parent.height;
            }

            TouchArea {
                clicked => { root.is-session-fullscreen = true; }
            }
        }

        Rectangle {
            height: UiVars.nav-height + root.bottom-safe;
            background: transparent;

            Rectangle {
                x: 0px;
                y: UiVars.nav-height;
                width: parent.width;
                height: root.bottom-safe;
                background: UiVars.nav-bg;
            }

            Panel {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: UiVars.nav-height;
                fill: UiVars.nav-bg;
                stroke: UiVars.nav-divider;
                border-width: UiVars.border-width;
                drop-shadow-color: UiVars.ink;
                drop-shadow-offset-x: 4px;
                drop-shadow-offset-y: 4px;
                drop-shadow-blur: 0px;
                z: 10;

                Rectangle {
                    x: UiVars.border-width;
                    y: UiVars.border-width;
                    width: parent.width - (UiVars.border-width * 2);
                    height: UiVars.nav-height - (UiVars.border-width * 2);
                    background: UiVars.nav-surface;
                }

                HorizontalLayout {
                    x: UiVars.border-width;
                    y: UiVars.border-width;
                    width: parent.width - (UiVars.border-width * 2);
                    height: UiVars.nav-height - (UiVars.border-width * 2);
                    alignment: space-around;

                NavItem {
                    label: "HOME";
                    glyph: "H";
                    active: root.selected-tab == 0;
                    tapped => { root.selected-tab = 0; dummy-focus.focus(); }
                }

                NavItem {
                    label: "EXERCISES";
                    glyph: "E";
                    active: root.selected-tab == 1;
                    tapped => { root.selected-tab = 1; dummy-focus.focus(); }
                }

                NavItem {
                    label: "STATS";
                    glyph: "S";
                    active: root.selected-tab == 3;
                    tapped => { root.selected-tab = 3; dummy-focus.focus(); }
                }

                NavItem {
                    label: "SETTINGS";
                    glyph: "⚙";
                    active: root.selected-tab == 4;
                    tapped => { root.selected-tab = 4; dummy-focus.focus(); }
                }
                }
            }
        }
    }

    if root.is-session-fullscreen : Rectangle {
        width: parent.width;
        height: parent.height;
        background: UiVars.screen-bg;
        z: 1000;

        // ── TOP SAFE AREA ──────────────────────────────────────────
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: root.top-safe;
            background: UiVars.screen-bg;
            z: 10;
        }

        // ── WORKOUT SCREEN (header + scroll, no finish button) ─────
        WorkoutScreen {
            width: parent.width;
            height: parent.height - root.top-safe - (UiVars.nav-height + root.bottom-safe) - 62px;
            y: root.top-safe;

            workout-sets: root.workout-sets;
            workout-exercises: root.workout-exercises;
            active-workout-title: root.active-workout-title;
            current-exercise-title: root.current-exercise-title;
            current-exercise-description: root.current-exercise-description;
            has-active-workout: root.has-active-workout;
            active-rest-timer <=> root.active-rest-timer;
            active-rest-duration: root.active-rest-duration;
            current-exercise-index: root.current-exercise-index;

            complete-set(exercise-index, set-index, reps, weight, duration) => {
                root.complete-set(exercise-index, set-index, reps, weight, duration);
            }

            finish-workout => {
                root.finish-workout();
                root.is-session-fullscreen = false;
                dummy-focus.focus();
            }

            minimize-session => {
                root.is-session-fullscreen = false;
                dummy-focus.focus();
            }

            add-active-set(exercise-index) => {
                root.add-active-set(exercise-index);
            }

            select-active-exercise(index) => {
                root.select-active-exercise(index);
            }
        }

        // ── FINISH WORKOUT BUTTON (fixed, above nav bar) ───────────
        Rectangle {
            x: 0;
            y: parent.height - (UiVars.nav-height + root.bottom-safe) - 62px;
            width: parent.width;
            height: 62px;
            background: UiVars.screen-bg;
            z: 20;

            // Top border line
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 2px;
                background: UiVars.ink;
            }

            Rectangle {
                x: UiVars.page-padding;
                y: 8px;
                width: parent.width - UiVars.page-padding * 2;
                height: 46px;
                background: UiVars.accent;
                border-color: UiVars.ink;
                border-width: UiVars.border-width;
                drop-shadow-color: UiVars.ink;
                drop-shadow-offset-x: 3px;
                drop-shadow-offset-y: 3px;
                drop-shadow-blur: 0px;

                Text {
                    text: "FINISH WORKOUT";
                    color: UiVars.ink;
                    font-size: 13px;
                    font-weight: 800;
                    letter-spacing: 1.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                }

                TouchArea {
                    clicked => {
                        root.finish-workout();
                        root.is-session-fullscreen = false;
                    }
                }
            }
        }

        // ── NAVIGATION BAR (bottom, always visible in session) ─────
        Rectangle {
            x: 0;
            y: parent.height - (UiVars.nav-height + root.bottom-safe);
            width: parent.width;
            height: UiVars.nav-height + root.bottom-safe;
            background: transparent;
            z: 20;

            Rectangle {
                x: 0px;
                y: UiVars.nav-height;
                width: parent.width;
                height: root.bottom-safe;
                background: UiVars.nav-bg;
            }

            Panel {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: UiVars.nav-height;
                fill: UiVars.nav-bg;
                stroke: UiVars.nav-divider;
                border-width: UiVars.border-width;
                drop-shadow-color: UiVars.ink;
                drop-shadow-offset-x: 4px;
                drop-shadow-offset-y: 4px;
                drop-shadow-blur: 0px;
                z: 10;

                Rectangle {
                    x: UiVars.border-width;
                    y: UiVars.border-width;
                    width: parent.width - (UiVars.border-width * 2);
                    height: UiVars.nav-height - (UiVars.border-width * 2);
                    background: UiVars.nav-surface;
                }

                HorizontalLayout {
                    x: UiVars.border-width;
                    y: UiVars.border-width;
                    width: parent.width - (UiVars.border-width * 2);
                    height: UiVars.nav-height - (UiVars.border-width * 2);
                    alignment: space-around;

                NavItem {
                    label: "HOME";
                    glyph: "H";
                    active: false;
                    tapped => {
                        root.is-session-fullscreen = false;
                        root.selected-tab = 0;
                        dummy-focus.focus();
                    }
                }

                NavItem {
                    label: "EXERCISES";
                    glyph: "E";
                    active: false;
                    tapped => {
                        root.is-session-fullscreen = false;
                        root.selected-tab = 1;
                        dummy-focus.focus();
                    }
                }

                NavItem {
                    label: "STATS";
                    glyph: "S";
                    active: false;
                    tapped => {
                        root.is-session-fullscreen = false;
                        root.selected-tab = 3;
                        dummy-focus.focus();
                    }
                }

                NavItem {
                    label: "SETTINGS";
                    glyph: "⚙";
                    active: false;
                    tapped => {
                        root.is-session-fullscreen = false;
                        root.selected-tab = 4;
                        dummy-focus.focus();
                    }
                }
                }
            }
        }
    }
}
